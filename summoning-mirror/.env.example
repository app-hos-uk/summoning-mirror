# Server
PORT=3001
NODE_ENV=production
BASE_URL=https://your-app.up.railway.app

# Admin credentials (REQUIRED in production)
ADMIN_EMAIL=admin@houseofspells.com
ADMIN_PASSWORD=

# Data & uploads (set to persistent volume in Railway)
DATA_DIR=
UPLOADS_DIR=

# SMTP (optional — email features disabled without these)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=House of Spells NYC

# Founder registration webhook (Google Apps Script URL — keep server-side only)
FOUNDER_REG_URL=

# Optional features
REQUIRE_EMAIL_VERIFICATION=false
LIFECYCLE_WORKER=true
